{
  "name": "local-llm-rn",
  "version": "0.1.0",
  "description": "Local LLM inference for React Native (iOS)",
  "main": "src/index.ts",
  "react-native": "src/index.ts",
  "files": [
    "src/",
    "ios/",
    "cpp/",
    "local-llm-rn.podspec",
    "!cpp/.gitkeep"
  ],
  "scripts": {
    "prepare": "bash scripts/prepare.sh",
    "prepack": "bash scripts/prepack.sh"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.76"
  },
  "dependencies": {
    "local-llm": "workspace:*"
  },
  "codegenConfig": {
    "name": "LocalLLMSpec",
    "type": "modules",
    "jsSrcsDir": "src"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hilum-labs/local-llm"
  }
}
